# 环境变量配置示例文件
# 复制此文件为 .env 并填入您的实际配置
# Copy this file to .env and fill in your actual configuration

# 数据源配置
# Data Source Configuration
DATA_SOURCE=local  # 可选: local, tushare, api

# 如果使用 TuShare API，填入您的 token
# If using TuShare API, fill in your token
TUSHARE_TOKEN=your_tushare_token_here

# 日志配置
# Logging Configuration
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR
LOG_FILE=logs/bank_valuation.log

# 报告输出路径
# Report Output Path
REPORT_DIR=reports/

# 数据缓存目录
# Data Cache Directory
DATA_CACHE_DIR=data/

# 可选: 使用代理（如需要）
# Optional: Use proxy if needed
HTTP_PROXY=
HTTPS_PROXY=

# 可选: 自定义数据源 API 端点
# Optional: Custom data source API endpoint
API_ENDPOINT=https://api.example.com

# 估值参数覆盖（可选）
# Valuation Parameters Override (Optional)
RISK_FREE_RATE=0.024
EQUITY_COST=0.10
MARKET_RISK_PREMIUM=0.07
PERPETUAL_GROWTH_RATE=0.04
